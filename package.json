{
  "name": "kidslearn",
  "productName": "KidsLearn",
  "version": "1.3.1",
  "description": "אפליקציית לימוד יומית לילדים",
  "main": "electron/main.cjs",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "cd server && node --watch index.js",
    "dev:client": "cd client && npm run dev",
    "install:all": "cd client && npm install && cd ../server && npm install",
    "build:client": "cd client && npm run build",
    "electron": "electron .",
    "dist": "npm run build:client && electron-builder --win",
    "dist:win": "npm run build:client && electron-builder --win",
    "dist:mac": "npm run build:client && electron-builder --mac",
    "dist:linux": "npm run build:client && electron-builder --linux",
    "dist:all": "npm run build:client && electron-builder -mwl"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^4.22.2",
    "nodemailer": "^6.10.1"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.kidslearn.app",
    "productName": "KidsLearn",
    "electronVersion": "42.2.0",
    "directories": {
      "output": "dist-electron",
      "buildResources": "build"
    },
    "files": [
      "electron/**/*",
      "server/**/*",
      "!server/data/config.json",
      "!server/data/history.json",
      "!server/data/review.json",
      "!server/server.log",
      "!server/server.err",
      "!server/.env",
      "client/dist/**/*",
      "kidslearn.ico",
      "package.json"
    ],
    "extraMetadata": {
      "main": "electron/main.cjs"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "kidslearn.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "KidsLearn"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "build/icon.png",
      "category": "public.app-category.education"
    },
    "dmg": {
      "title": "KidsLearn"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "build/icon.png",
      "category": "Education",
      "maintainer": "deanavraham-bit"
    },
    "asar": false
  }
}
