# ─── Dependencies ─────────────────────────────────────────────
node_modules/
*/node_modules/

# ─── Build outputs ───────────────────────────────────────────
client/dist/
dist-electron/
*.tsbuildinfo

# ─── Private / sensitive data (DO NOT COMMIT) ────────────────
# Contains SMTP password, recipient emails, child history, etc.
server/data/*
# …but DO keep the sample config so other machines know what fields to fill in
!server/data/config.sample.json
*.log
server/server.log
server/server.err

# Private family photos — LOCAL ONLY (kept out of the public repo / web).
# They live only on our own machine and are bundled into the local build.
# Generic pattern so no names are revealed in the public repo.
client/public/*.png
docs/app/*.png

# ─── Editor / OS junk ────────────────────────────────────────
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# ─── npm / Node ──────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm/
.env
.env.local
.env.*.local

# ─── Misc ────────────────────────────────────────────────────
*.bak
*.tmp
.cache/
WebsiteBuilder/

